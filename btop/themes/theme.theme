# Theme: github-dark
# By: azada

# Main bg
theme[main_bg]="#0d1117"

# Main text color
theme[main_fg]="#c9d1d9"

# Title color for boxes
theme[title]="#c9d1d9"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#58a6ff"

# Background color of selected item in processes box
theme[selected_bg]="#161b22"

# Foreground color of selected item in processes box
theme[selected_fg]="#c9d1d9"

# Color of inactive/disabled text
theme[inactive_fg]="#6e7681"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#58a6ff"

# Cpu box outline color
theme[cpu_box]="#30363d"

# Memory/disks box outline color
theme[mem_box]="#30363d"

# Net up/down box outline color
theme[net_box]="#30363d"

# Processes box outline color
theme[proc_box]="#30363d"

# Box divider line and small boxes line color
theme[div_line]="#30363d"

# Temperature graph colors
theme[temp_start]="#3fb950"
theme[temp_mid]="#d29922"
theme[temp_end]="#f85149"

# CPU graph colors
theme[cpu_start]="#3fb950"
theme[cpu_mid]="#d29922"
theme[cpu_end]="#f85149"

# Mem/Disk free meter
theme[free_start]="#3fb950"
theme[free_mid]="#d29922"
theme[free_end]="#f85149"

# Mem/Disk cached meter
theme[cached_start]="#3fb950"
theme[cached_mid]="#d29922"
theme[cached_end]="#f85149"

# Mem/Disk available meter
theme[available_start]="#3fb950"
theme[available_mid]="#d29922"
theme[available_end]="#f85149"

# Mem/Disk used meter
theme[used_start]="#3fb950"
theme[used_mid]="#d29922"
theme[used_end]="#f85149"

# Download graph colors
theme[download_start]="#3fb950"
theme[download_mid]="#d29922"
theme[download_end]="#f85149"

# Upload graph colors
theme[upload_start]="#3fb950"
theme[upload_mid]="#d29922"
theme[upload_end]="#f85149"
